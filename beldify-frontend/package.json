{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fast": "NEXT_TURBO=1 NODE_OPTIONS='--max-old-space-size=4096' next dev --turbo",
    "dev:debug": "NODE_OPTIONS='--max-old-space-size=4096' NEXT_PUBLIC_DEBUG_MODE=false next dev --turbo -p 3000",
    "docker:dev": "docker-compose up --build",
    "build:dev": "cp next.config.js next.config.build.js && next build && rm next.config.build.js",
    "build:prod": "cp next.config.js next.config.dev.bak && cp next.config.prod.js next.config.js && next build --no-lint; mv next.config.dev.bak next.config.js",
    "start:dev": "next start -p 3001 -H 0.0.0.0",
    "start:prod": "next start -p 7894 -H 0.0.0.0",
    "lint": "next lint",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:coverage": "vitest run --coverage --config vitest.config.mts",
    "test:ui": "vitest --ui --config vitest.config.mts",
    "mcp:frontend": "tsx frontend-mcp-server.ts",
    "mcp:frontend:http": "tsx frontend-mcp-server.ts --http",
    "mcp:frontend:stdio": "tsx frontend-mcp-server.ts --stdio",
    "analyze": "ANALYZE=true npm run build:prod"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.5.9",
    "@headlessui/react": "^2.2.3",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@serwist/next": "^9.5.11",
    "axios": "^1.12.2",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "cors": "^2.8.5",
    "critters": "^0.0.25",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "framer-motion": "^11.18.2",
    "i18next": "^25.4.1",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-http-backend": "^3.0.1",
    "isomorphic-dompurify": "^2.26.0",
    "js-cookie": "^3.0.5",
    "laravel-echo": "^1.19.0",
    "lucide-react": "^0.473.0",
    "negotiator": "^1.0.0",
    "node-cache": "^5.1.2",
    "pusher-js": "^8.4.0",
    "react": "19.0.0",
    "react-datepicker": "8.3.0",
    "react-dom": "19.0.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.56.4",
    "react-hot-toast": "^2.5.2",
    "react-i18next": "^15.2.0",
    "react-icons": "^5.4.0",
    "serwist": "^9.5.11",
    "swiper": "^11.1.15",
    "swr": "^2.4.0",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@heroicons/react": "^2.2.0",
    "@next/bundle-analyzer": "^15.3.3",
    "@next/eslint-plugin-next": "^15.3.3",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/axios": "^0.14.4",
    "@types/js-cookie": "^3.0.6",
    "@types/negotiator": "^0.6.3",
    "@types/node": "^20.17.46",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-i18next": "^7.8.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "dotenv": "^17.2.2",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.33.2",
    "jsdom": "^25.0.1",
    "msw": "^2.6.6",
    "next": "^15.3.2",
    "nodemon": "^3.1.10",
    "playwright": "^1.55.0",
    "postcss": "^8.4.49",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.3.0",
    "vitest": "^2.1.8"
  }
}
