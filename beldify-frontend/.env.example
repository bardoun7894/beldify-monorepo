# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the Laravel backend. Used for all REST calls and as the default
# host/auth endpoint for the realtime (Reverb) websocket.
NEXT_PUBLIC_API_URL=https://api.beldify.com

# ── Realtime messaging (Laravel Reverb / Pusher protocol) ─────────────────────
# App key configured in the backend's Reverb config. REQUIRED for realtime chat
# to connect — if unset, the messaging pages silently fall back to polling.
NEXT_PUBLIC_REVERB_APP_KEY=

# Websocket host. Optional — defaults to the hostname of NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_REVERB_HOST=

# Websocket port. Optional — defaults to 8082.
NEXT_PUBLIC_REVERB_PORT=8082

# Transport scheme: "https" (TLS, wss://) or "http" (plain, ws:// — local dev).
# Optional — defaults to "https". Set to "http" for a local non-TLS Reverb.
NEXT_PUBLIC_REVERB_SCHEME=https
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
