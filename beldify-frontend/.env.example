# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the Laravel backend. Used for all REST calls and as the default
# host/auth endpoint for the realtime (Reverb) websocket.
NEXT_PUBLIC_API_URL=https://api.beldify.com

# ── Site / app URLs ───────────────────────────────────────────────────────────
# Canonical frontend URL — used in sitemap.xml and structured data (JSON-LD).
NEXT_PUBLIC_SITE_URL=https://www.beldify.com

# App URL for CORS allowed-origins list (defaults to localhost:3000 in dev).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Storage / media ───────────────────────────────────────────────────────────
# Public CDN/storage URL for product images. Appended to relative image paths.
NEXT_PUBLIC_STORAGE_URL=https://pro.beldify.com/storage

# Storage origin (host only, no path). Used to detect storage-hosted images.
NEXT_PUBLIC_STORAGE_ORIGIN=https://pro.beldify.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google OAuth 2.0 client ID from https://console.cloud.google.com/.
# When unset the Google Sign-In / One-Tap button is hidden completely.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Support contact ───────────────────────────────────────────────────────────
# WhatsApp / phone number shown on checkout payment-proof upload screen.
NEXT_PUBLIC_SUPPORT_PHONE=+212708150351

# ── Debug mode ────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose console logging in the browser.
NEXT_PUBLIC_DEBUG_MODE=false

# ── Realtime messaging (Laravel Reverb / Pusher protocol) ─────────────────────
# App key configured in the backend's Reverb config. REQUIRED for realtime chat
# to connect — if unset, the messaging pages silently fall back to polling.
NEXT_PUBLIC_REVERB_APP_KEY=

# Websocket host. Optional — defaults to the hostname of NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_REVERB_HOST=

# Websocket port. Optional — defaults to 8082.
NEXT_PUBLIC_REVERB_PORT=8082

# Transport scheme: "https" (TLS, wss://) or "http" (plain, ws:// — local dev).
# Optional — defaults to "https". Set to "http" for a local non-TLS Reverb.
NEXT_PUBLIC_REVERB_SCHEME=https
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Analytics (set to activate; leave empty = vendor no-ops, zero noise) ─────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Used directly when NEXT_PUBLIC_GTM_ID is absent; ignored when GTM is set
# because GTM handles GA4 injection via the GTM container tag.
NEXT_PUBLIC_GA4_ID=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX).
# When set, GTM is injected and NEXT_PUBLIC_GA4_ID is managed via GTM.
NEXT_PUBLIC_GTM_ID=

# Meta (Facebook) Pixel ID — numeric string from Events Manager.
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel ID — alphanumeric string from TikTok Ads Manager.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
